# DeKalb Database — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# The .env file is gitignored — never commit it.

# ---------------------------------------------------------------
# IBKR Client Portal Gateway
# ---------------------------------------------------------------
# Your IBKR account ID. Find it in IBKR → Account → Account Summary.
# Format: U followed by digits, e.g. U1234567
IBKR_ACCOUNT_ID=

# Set to true once the gateway is running and you've authenticated in the browser.
# When false, the API falls back to yfinance for market data.
IBKR_ENABLED=false

# Where the gateway is listening.
# - Local (running API directly): https://localhost:5000
# - Docker (running via docker-compose): https://host.docker.internal:5000
IBKR_GATEWAY_URL=https://localhost:5000

# ---------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------
# Only needed if you're overriding the defaults.
# Default: localhost for local dev, set to 'postgres' in Docker (handled by docker-compose).
# DB_HOST=localhost
# POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------
# Trade Tracker API tuning (optional)
# ---------------------------------------------------------------
# How long to cache yfinance price lookups before re-fetching (seconds)
# PRICE_CACHE_TTL_SECONDS=60

# Enable verbose debug logging
# DEBUG=false
