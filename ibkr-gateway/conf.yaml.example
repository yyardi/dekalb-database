listenPort: 5000
listenSsl: true

# SSL cert for the gateway's local HTTPS server (bundled with the gateway download)
sslCert: "root/conf/cacert.jks"
sslPwd: "test"

appVersion: "1.0"
authVersion: "0.0.1"
baseUrl: "api.ibkr.com"

oauth:
  # Fill these in when you get them from your manager:
  consumerKey: "YOUR_CONSUMER_KEY_HERE"

  # Path to your private key .pem file (relative to the gateway folder)
  privateKeyPath: "root/conf/private_key.pem"

  # Realm — use "limited_poa" for read-only, "test_realm" for paper trading
  realm: "limited_poa"
