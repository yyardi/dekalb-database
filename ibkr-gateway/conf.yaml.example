# IBKR Client Portal Gateway — conf.yaml
#
# You do NOT need to create this file manually.
# The gateway download already includes a working root/conf/conf.yaml
# and the required root/conf/cacert.jks SSL certificate.
#
# To start the gateway, just run from ibkr-gateway/clientportal.gw/:
#   ./bin/run.sh root/conf       (Linux/Mac)
#   bin\run.bat root/conf        (Windows)
#
# Then open https://localhost:5000 in your browser and log in with
# your IBKR username + password + 2FA.
#
# Only edit the bundled conf.yaml if you need to change the port (default 5000).
# The only field most people ever change:
#
#   listenPort: 5000
