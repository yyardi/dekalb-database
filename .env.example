# DeKalb Database — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# The .env file is gitignored — never commit it.

# ---------------------------------------------------------------
# IBKR Web API (OAuth 2.0)
# Register your app at IBKR Client Portal → Settings → API → Register Application
# ---------------------------------------------------------------

# Set to true once you have your OAuth credentials below
IBKR_ENABLED=false

# From IBKR developer portal after registering your app
IBKR_CLIENT_ID=
IBKR_CLIENT_SECRET=

# Your IBKR account ID — shown top-right in Client Portal (format: U1234567)
IBKR_ACCOUNT_ID=

# Where IBKR sends the user after they log in
# Local dev:   http://localhost:8000/ibkr/auth/callback
# Production:  https://your-api.railway.app/ibkr/auth/callback
IBKR_REDIRECT_URI=http://localhost:8000/ibkr/auth/callback

# Your frontend URL — used for CORS and post-auth redirect
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------
# PostgreSQL (only needed if overriding defaults)
# ---------------------------------------------------------------
# DB_HOST=localhost           # 'postgres' when running in Docker (handled automatically)
# POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------
# Optional tuning
# ---------------------------------------------------------------
# PRICE_CACHE_TTL_SECONDS=60   # how long to cache yfinance price lookups
# DEBUG=false                  # verbose API logging
