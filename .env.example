# DeKalb Database — Environment Variables
# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored — never commit it.

# ---------------------------------------------------------------
# IBKR Web API — RSA key-based, server-to-server
#
# How it works: your RSA private key signs a JWT → IBKR gives you
# a bearer token → you create a session → API calls work.
# No browser login. No redirect. Fully automatic once set up.
# ---------------------------------------------------------------

# Set to true once all credentials below are filled in
IBKR_ENABLED=false

# Paper account credentials
# IBKR_CLIENT_ID=DekalbCapital-Paper
# IBKR_CLIENT_KEY_ID=main
# IBKR_CREDENTIAL=dekalbcapitalpaper
# IBKR_ACCOUNT_ID=DFP321877

# Live / Production account (F account — private key from Ryan's zip)
IBKR_CLIENT_ID=DekalbCapital-Prod
IBKR_CLIENT_KEY_ID=main
IBKR_CREDENTIAL=dekalbcapital3
IBKR_ACCOUNT_ID=F16173704

# Your RSA private key. Three formats work — use whichever matches what you have:
#
#   Option A (easiest): if your key is already base64-encoded (one long string ending in ==)
#   just paste it directly — no quotes, no escaping needed:
#   IBKR_PRIVATE_KEY=LS0tLS1CRUdJTiBSU0EgUFJJVkFURSBLRVktLS0tLQ==...
#
#   Option B: raw PEM with \n for each newline (all on one line):
#   IBKR_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEowIB...\n-----END RSA PRIVATE KEY-----
#
# NEVER commit this file or share this key.
IBKR_PRIVATE_KEY=

# The outbound IP address of the server making IBKR API calls.
# Local dev:  google "what is my ip" and paste it here
# Railway:    Settings → Networking → Outbound Static IP (requires Pro plan)
# If left blank, the app will try to auto-detect it (less reliable).
IBKR_SERVER_IP=

# ---------------------------------------------------------------
# Frontend URL — used for CORS
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
# ---------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------
# PostgreSQL (only needed if overriding defaults)
# ---------------------------------------------------------------
# DB_HOST=localhost
# POSTGRES_PASSWORD=postgres

# ---------------------------------------------------------------
# Optional tuning
# ---------------------------------------------------------------
# PRICE_CACHE_TTL_SECONDS=60
# DEBUG=false
